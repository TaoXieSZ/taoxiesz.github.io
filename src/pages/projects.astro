---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { PROJECTS } from '../consts';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const projectCounts = new Map<string, number>();
for (const post of posts) {
  if (post.data.project) {
    projectCounts.set(post.data.project, (projectCounts.get(post.data.project) || 0) + 1);
  }
}
---

<BaseLayout title="项目 | 谢韬的工作台" description="近期项目和长期维护方向。">
  <section class="card hero">
    <div class="eyebrow">项目</div>
    <h1>公开的项目清单</h1>
    <p class="muted">长期维护的脚本、自动化链路和产品化尝试。</p>
  </section>

  <section class="grid" style="margin-top: 20px;">
    {Object.entries(PROJECTS).map(([key, meta]) => {
      const count = projectCounts.get(key) || 0;
      return (
        <a href={`/blog/${key}/`} class="project-link">
          <article class="card">
            <h2>{meta.label}</h2>
            <p class="muted">{meta.description}</p>
            <div class="project-meta">
              {count > 0
                ? <span>{count} 篇文章</span>
                : <span class="muted">暂无文章</span>
              }
              <span class="arrow">&rarr;</span>
            </div>
          </article>
        </a>
      );
    })}
  </section>
</BaseLayout>

<style>
  .project-link {
    text-decoration: none;
    color: inherit;
  }
  .project-link:hover {
    text-decoration: none;
  }
  .project-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 12px;
    padding-top: 12px;
    border-top: 1px solid var(--line);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--muted);
  }
  .arrow {
    transition: transform 0.2s;
  }
  .card:hover .arrow {
    transform: translateX(4px);
  }
</style>
