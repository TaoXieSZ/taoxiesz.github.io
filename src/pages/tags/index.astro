---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const tagMap = new Map<string, number>();
for (const post of posts) {
  for (const tag of post.data.tags) {
    tagMap.set(tag, (tagMap.get(tag) || 0) + 1);
  }
}
const tags = [...tagMap.entries()].sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="标签 | 谢韬的工作台" description="按标签浏览所有文章。">
  <section class="card hero">
    <div class="eyebrow">标签</div>
    <h1>按标签浏览</h1>
    <p class="muted">共 {tags.length} 个标签，{posts.length} 篇文章。</p>
  </section>

  <section class="card" style="margin-top: 20px;">
    <div class="tags-cloud">
      {tags.map(([tag, count]) => (
        <a href={`/tags/${encodeURIComponent(tag)}/`} class="tag-pill">
          <span class="tag-name">#{tag}</span>
          <span class="tag-count">{count}</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .tags-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .tag-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    border-radius: 8px;
    border: 1px solid var(--line);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text);
    transition: all 0.2s;
  }
  .tag-pill:hover {
    border-color: var(--accent);
    background: var(--accent-soft);
    color: var(--accent);
    text-decoration: none;
  }
  .tag-count {
    font-size: 0.72rem;
    color: var(--muted);
    background: var(--bg);
    padding: 1px 6px;
    border-radius: 4px;
  }
</style>
