---
import { SITE_DESCRIPTION, SITE_NAV, SITE_TITLE, SITE_URL } from '../consts';
import ClawdMascot from '../components/ClawdMascot.astro';

interface Props {
  title?: string;
  description?: string;
  ogType?: 'website' | 'article';
  publishedTime?: Date;
}

const { title = SITE_TITLE, description = SITE_DESCRIPTION, ogType = 'website', publishedTime } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, SITE_URL);
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content={SITE_TITLE} />
    <meta property="og:image" content={new URL('/og-default.svg', SITE_URL)} />
    {publishedTime && <meta property="article:published_time" content={publishedTime.toISOString()} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL('/og-default.svg', SITE_URL)} />
    <link rel="alternate" type="application/rss+xml" title={SITE_TITLE} href="/rss.xml" />
    <link rel="preload" href="/fonts/MapleMono-Regular.ttf.woff2" as="font" type="font/woff2" crossorigin />
    <script is:inline>
      (function() {
        var theme = localStorage.getItem('theme');
        if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.dataset.theme = 'dark';
        }
      })();
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">跳转到主要内容</a>
    <div class="grain"></div>
    <div class="shell">
      <header class="site-header">
        <a class="brand" href="/">
          <span class="brand-cursor">_</span>{SITE_TITLE}
        </a>
        <div class="header-right">
          <nav>
            {SITE_NAV.map((item) => (
              <a href={item.href} aria-current={currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href)) ? 'page' : undefined}>{item.label}</a>
            ))}
          </nav>
          <button class="theme-toggle" id="theme-toggle" aria-label="切换主题">
            <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
            <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          </button>
        </div>
      </header>
      <main id="main-content">
        <slot />
      </main>
      <footer class="site-footer">
        <div class="footer-line"></div>
        <p><span class="footer-mono">built with</span> Astro <span class="footer-mono">·</span> deployed on <span class="footer-mono">GitHub Pages</span></p>
      </footer>
    </div>
    <ClawdMascot />
    <script>
      const btn = document.getElementById('theme-toggle');
      btn?.addEventListener('click', () => {
        const isDark = document.documentElement.dataset.theme === 'dark';
        if (isDark) {
          delete document.documentElement.dataset.theme;
          localStorage.setItem('theme', 'light');
        } else {
          document.documentElement.dataset.theme = 'dark';
          localStorage.setItem('theme', 'dark');
        }
      });
    </script>
  </body>
</html>

<style is:global>
  @font-face {
    font-family: 'Maple Mono';
    font-style: normal;
    font-weight: 400;
    font-display: swap;
    src: url('/fonts/MapleMono-Regular.ttf.woff2') format('woff2');
  }
  @font-face {
    font-family: 'Maple Mono';
    font-style: normal;
    font-weight: 500;
    font-display: swap;
    src: url('/fonts/MapleMono-Medium.ttf.woff2') format('woff2');
  }
  @font-face {
    font-family: 'Maple Mono';
    font-style: normal;
    font-weight: 600;
    font-display: swap;
    src: url('/fonts/MapleMono-SemiBold.ttf.woff2') format('woff2');
  }
  @font-face {
    font-family: 'Maple Mono';
    font-style: normal;
    font-weight: 700;
    font-display: swap;
    src: url('/fonts/MapleMono-Bold.ttf.woff2') format('woff2');
  }
  @font-face {
    font-family: 'Maple Mono';
    font-style: italic;
    font-weight: 400;
    font-display: swap;
    src: url('/fonts/MapleMono-Italic.ttf.woff2') format('woff2');
  }
  @font-face {
    font-family: 'Maple Mono';
    font-style: italic;
    font-weight: 700;
    font-display: swap;
    src: url('/fonts/MapleMono-BoldItalic.ttf.woff2') format('woff2');
  }
  :root {
    color-scheme: light dark;
    --bg: #f6f4ee;
    --surface: #fdfcf8;
    --surface-hover: #f1eee5;
    --text: #1c1a15;
    --muted: #6d675a;
    --line: #e0dbcd;
    --accent: #22624a;
    --accent-soft: #e7efe9;
    --max: 880px;
    --font-body: 'Maple Mono', 'PingFang SC', 'Hiragino Sans GB', ui-monospace, 'SFMono-Regular', 'Menlo', monospace;
    --font-mono: 'Maple Mono', 'PingFang SC', 'Hiragino Sans GB', ui-monospace, 'SFMono-Regular', 'Menlo', monospace;
    --radius: 10px;
  }
  [data-theme="dark"] {
    --bg: #14120e;
    --surface: #1c1913;
    --surface-hover: #221f18;
    --text: #e9e4d8;
    --muted: #9b937f;
    --line: #322e24;
    --accent: #63b391;
    --accent-soft: #1a2b22;
  }
  [data-theme="dark"] body { background: var(--bg); }

  * { box-sizing: border-box; }

  html {
    font-family: var(--font-body);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    line-height: 1.75;
    position: relative;
    font-size: 16px;
  }

  /* ── Subtle grain overlay ── */
  .grain {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 0.02;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
    background-size: 200px;
  }
  [data-theme="dark"] .grain { opacity: 0.035; }

  a { color: var(--accent); text-decoration: none; }
  a:hover { text-decoration: underline; text-underline-offset: 3px; }

  .shell {
    max-width: var(--max);
    margin: 0 auto;
    padding: 24px 24px 88px;
    position: relative;
    z-index: 2;
  }
  .shell:has(.post-layout.has-toc) { --max: 1180px; }

  /* ── Header ── */
  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 14px 0 44px;
  }
  .brand {
    font-family: var(--font-mono);
    font-size: 0.98rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.02em;
    display: flex;
    align-items: center;
    gap: 2px;
  }
  .brand:hover { text-decoration: none; color: var(--accent); }
  .brand-cursor {
    color: var(--accent);
    animation: blink-cursor 1.2s step-end infinite;
    font-weight: 400;
  }
  @keyframes blink-cursor {
    0%, 50% { opacity: 1; }
    51%, 100% { opacity: 0; }
  }

  .header-right { display: flex; align-items: center; gap: 18px; }
  nav { display: flex; gap: 2px; flex-wrap: wrap; }
  nav a {
    color: var(--muted);
    font-weight: 500;
    font-size: 0.9rem;
    padding: 4px 10px;
    border-radius: 6px;
    border-bottom: 2px solid transparent;
    transition: color 0.15s;
  }
  nav a:hover { color: var(--text); text-decoration: none; }
  nav a[aria-current="page"] {
    color: var(--text);
    font-weight: 600;
    border-bottom-color: var(--accent);
    border-radius: 0;
  }

  /* ── Typography ── */
  h1, h2, h3 {
    font-family: var(--font-body);
    line-height: 1.28;
    margin: 0 0 12px;
    letter-spacing: -0.015em;
    text-wrap: balance;
  }
  h1 { font-weight: 700; font-size: 1.9rem; }
  h2 { font-weight: 700; font-size: 1.25rem; }
  h3 { font-weight: 600; font-size: 1.05rem; }
  p { margin: 0 0 16px; }

  /* ── Cards (kept for interior pages, flattened) ── */
  .card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 22px;
    transition: border-color 0.2s ease, background 0.2s ease;
  }
  .card:hover { border-color: var(--accent); background: var(--surface-hover); }

  .hero { padding: 0; border: none; background: transparent; }
  .hero:hover { background: transparent; border: none; }

  .eyebrow {
    display: inline-flex;
    gap: 8px;
    align-items: center;
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.76rem;
    font-weight: 600;
    margin-bottom: 14px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .eyebrow::before { content: ""; width: 22px; height: 2px; background: var(--accent); }

  .muted { color: var(--muted); }

  .grid { display: grid; gap: 18px; }
  .posts { grid-template-columns: 1fr; gap: 0; }
  .meta {
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.8rem;
  }

  .tag-list { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 10px; }
  .tag {
    display: inline-block;
    border-radius: 5px;
    border: 1px solid var(--line);
    background: transparent;
    color: var(--muted);
    padding: 1px 8px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    transition: color 0.15s, border-color 0.15s;
  }
  .tag:hover { border-color: var(--accent); color: var(--accent); text-decoration: none; }

  /* ── Footer ── */
  .site-footer {
    padding-top: 36px;
    color: var(--muted);
    font-size: 0.85rem;
  }
  .footer-line {
    width: 40px;
    height: 2px;
    background: var(--accent);
    margin-bottom: 16px;
    border-radius: 1px;
  }
  .footer-mono { font-family: var(--font-mono); font-size: 0.8rem; }

  /* ── Theme toggle ── */
  .theme-toggle {
    background: none;
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 7px;
    cursor: pointer;
    color: var(--muted);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }
  .theme-toggle:hover {
    background: var(--accent-soft);
    color: var(--accent);
    border-color: var(--accent);
  }
  .theme-toggle .icon-sun { display: none; }
  .theme-toggle .icon-moon { display: block; }
  [data-theme="dark"] .theme-toggle .icon-sun { display: block; }
  [data-theme="dark"] .theme-toggle .icon-moon { display: none; }

  /* ── Prose (article pages): open reading column, no card chrome ── */
  article.prose {
    background: transparent;
    border: none;
    border-radius: 0;
    padding: 8px 0 0;
    max-width: 72ch;
  }
  article.prose h2, article.prose h3 { margin-top: 40px; }
  article.prose h2 {
    font-size: 1.32rem;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--line);
  }
  article.prose code {
    background: var(--accent-soft);
    border-radius: 5px;
    padding: 0.12rem 0.38rem;
    font-family: var(--font-mono);
    font-size: 0.86em;
  }
  [data-theme="dark"] article.prose code { background: #24312a; }
  article.prose blockquote {
    margin: 0 0 16px;
    padding: 2px 0 2px 18px;
    border-left: 3px solid var(--accent);
    color: var(--muted);
  }
  article.prose img { max-width: 100%; border-radius: var(--radius); }

  /* Shiki dual-theme */
  .astro-code,
  .astro-code span {
    color: var(--shiki-light) !important;
    background-color: var(--shiki-light-bg) !important;
  }
  [data-theme="dark"] .astro-code,
  [data-theme="dark"] .astro-code span {
    color: var(--shiki-dark) !important;
    background-color: var(--shiki-dark-bg) !important;
  }

  article.prose pre {
    overflow-x: auto;
    padding: 18px 20px;
    border-radius: var(--radius);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    line-height: 1.65;
    border: 1px solid var(--line);
  }
  article.prose pre code { background: transparent !important; padding: 0; }
  ul { padding-left: 1.25rem; }

  /* ── Entrance (single, restrained) ── */
  @keyframes fade-up {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  main > * { animation: fade-up 0.4s ease both; }
  main > *:nth-child(2) { animation-delay: 0.06s; }
  main > *:nth-child(3) { animation-delay: 0.12s; }

  @media (max-width: 640px) {
    .site-header { align-items: flex-start; flex-direction: column; }
    .card { padding: 18px; }
    h1 { font-size: 1.55rem; }
  }

  .skip-link {
    position: absolute;
    left: -9999px;
    top: 4px;
    z-index: 100;
    padding: 8px 16px;
    background: var(--accent);
    color: #fff;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 600;
  }
  .skip-link:focus { left: 16px; }

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>
